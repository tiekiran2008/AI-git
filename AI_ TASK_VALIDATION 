      "source": [
        "import nbformat\n",
        "\n",
        "def extract_ipynb(file):\n",
        "    nb = nbformat.read(file, as_version=4)\n",
        "    text = \"\"\n",
        "\n",
        "    for cell in nb.cells:\n",
        "        if cell.cell_type == \"code\":\n",
        "            text += cell.source\n",
        "\n",
        "    return text"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "oMt39TKE80xN"
      },
      "outputs": [],
      "source": [
        "def get_embedding(text):\n",
        "    return model.encode(text)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "3SM6wxGf81_D"
      },
      "outputs": [],
      "source": [
        "from sklearn.metrics.pairwise import cosine_similarity\n",
        "\n",
        "def get_similarity(text1, text2):\n",
        "    emb1 = get_embedding(text1)\n",
        "    emb2 = get_embedding(text2)\n",
        "\n",
        "    return cosine_similarity([emb1], [emb2])[0][0]"
      ]
    },
    {
      "cell_type": "code",
